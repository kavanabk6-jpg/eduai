<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>EduAI – AI Student Simulator</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet"/>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0b0f1a;
    --surface: #131929;
    --surface2: #1a2235;
    --border: #1e2d45;
    --accent: #3b82f6;
    --accent2: #06b6d4;
    --green: #10b981;
    --yellow: #f59e0b;
    --red: #ef4444;
    --text: #e2e8f0;
    --muted: #64748b;
    --font-display: 'Syne', sans-serif;
    --font-body: 'DM Sans', sans-serif;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Background grid */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(59,130,246,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(59,130,246,0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* Glow blobs */
  .blob {
    position: fixed;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.12;
    pointer-events: none;
    z-index: 0;
  }
  .blob-1 { width: 500px; height: 500px; background: #3b82f6; top: -100px; left: -100px; }
  .blob-2 { width: 400px; height: 400px; background: #06b6d4; bottom: -100px; right: -100px; }

  /* Layout */
  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }

  /* Header */
  header {
    padding: 28px 0 20px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 40px;
  }
  .header-inner { display: flex; align-items: center; gap: 14px; }
  .logo-icon {
    width: 44px; height: 44px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
    box-shadow: 0 0 20px rgba(59,130,246,0.3);
  }
  .logo-text { font-family: var(--font-display); font-size: 22px; font-weight: 800; letter-spacing: -0.5px; }
  .logo-text span { color: var(--accent2); }
  .badge {
    margin-left: auto;
    background: rgba(59,130,246,0.12);
    border: 1px solid rgba(59,130,246,0.25);
    color: var(--accent);
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  /* Hero */
  .hero { text-align: center; margin-bottom: 48px; }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(28px, 5vw, 48px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -1px;
    margin-bottom: 14px;
  }
  .hero h1 .gradient {
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero p { color: var(--muted); font-size: 16px; max-width: 480px; margin: 0 auto; line-height: 1.6; }

  /* Upload card */
  .upload-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 36px;
    margin-bottom: 32px;
    transition: border-color 0.2s;
  }
  .upload-card:hover { border-color: rgba(59,130,246,0.3); }

  .upload-zone {
    border: 2px dashed var(--border);
    border-radius: 14px;
    padding: 40px 24px;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
    margin-bottom: 20px;
    background: rgba(59,130,246,0.02);
  }
  .upload-zone:hover, .upload-zone.drag-over {
    border-color: var(--accent);
    background: rgba(59,130,246,0.06);
  }
  .upload-icon { font-size: 36px; margin-bottom: 10px; }
  .upload-zone h3 { font-family: var(--font-display); font-size: 16px; font-weight: 700; margin-bottom: 6px; }
  .upload-zone p { color: var(--muted); font-size: 13px; }
  .upload-zone input { display: none; }

  .textarea-label { font-size: 13px; font-weight: 500; color: var(--muted); margin-bottom: 8px; display: block; text-transform: uppercase; letter-spacing: 0.5px; }
  textarea {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.6;
    padding: 16px;
    resize: vertical;
    min-height: 140px;
    transition: border-color 0.2s;
    outline: none;
  }
  textarea:focus { border-color: var(--accent); }
  textarea::placeholder { color: var(--muted); }

  .analyze-btn {
    width: 100%;
    margin-top: 16px;
    padding: 16px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border: none;
    border-radius: 12px;
    color: white;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    letter-spacing: 0.3px;
  }
  .analyze-btn:hover { opacity: 0.9; transform: translateY(-1px); }
  .analyze-btn:active { transform: translateY(0); }
  .analyze-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  /* Loading */
  .loading {
    display: none;
    text-align: center;
    padding: 48px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    margin-bottom: 32px;
  }
  .loading.show { display: block; }
  .spinner {
    width: 48px; height: 48px;
    border: 3px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 16px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .loading p { color: var(--muted); font-size: 14px; }
  .loading-steps { margin-top: 16px; display: flex; flex-direction: column; gap: 8px; align-items: center; }
  .step { font-size: 12px; color: var(--muted); display: flex; align-items: center; gap: 6px; opacity: 0; animation: fadeUp 0.4s forwards; }
  .step.active { color: var(--accent2); opacity: 1; }
  @keyframes fadeUp { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

  /* Results */
  .results { display: none; }
  .results.show { display: block; }

  .results-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 24px;
    flex-wrap: wrap; gap: 12px;
  }
  .results-header h2 { font-family: var(--font-display); font-size: 22px; font-weight: 800; }
  .reset-btn {
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--muted);
    padding: 8px 16px;
    border-radius: 8px;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--font-body);
  }
  .reset-btn:hover { color: var(--text); border-color: rgba(59,130,246,0.3); }

  /* Score cards */
  .scores-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 24px; }
  .score-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, border-color 0.2s;
    animation: cardIn 0.5s ease both;
  }
  .score-card:hover { transform: translateY(-2px); border-color: rgba(59,130,246,0.25); }
  @keyframes cardIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  .score-card:nth-child(1) { animation-delay: 0.0s; }
  .score-card:nth-child(2) { animation-delay: 0.08s; }
  .score-card:nth-child(3) { animation-delay: 0.16s; }
  .score-card:nth-child(4) { animation-delay: 0.24s; }

  .score-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; color: var(--muted); margin-bottom: 10px; }
  .score-value {
    font-family: var(--font-display);
    font-size: 42px;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 6px;
  }
  .score-bar { height: 4px; background: var(--border); border-radius: 4px; overflow: hidden; }
  .score-fill { height: 100%; border-radius: 4px; transition: width 1s cubic-bezier(0.4, 0, 0.2, 1); width: 0%; }

  .score-good .score-value, .score-good .score-fill { color: var(--green); background: var(--green); }
  .score-mid .score-value, .score-mid .score-fill { color: var(--yellow); background: var(--yellow); }
  .score-low .score-value, .score-low .score-fill { color: var(--red); background: var(--red); }

  .difficulty-badge {
    display: inline-block;
    font-size: 14px;
    font-weight: 700;
    font-family: var(--font-display);
    padding: 4px 12px;
    border-radius: 999px;
    margin-top: 4px;
  }
  .difficulty-Easy { background: rgba(16,185,129,0.15); color: var(--green); }
  .difficulty-Medium { background: rgba(245,158,11,0.15); color: var(--yellow); }
  .difficulty-Hard { background: rgba(239,68,68,0.15); color: var(--red); }

  /* Feedback panels */
  .feedback-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
  @media (max-width: 640px) { .feedback-grid { grid-template-columns: 1fr; } }

  .feedback-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
    animation: cardIn 0.5s ease both;
  }
  .feedback-panel:nth-child(1) { animation-delay: 0.3s; }
  .feedback-panel:nth-child(2) { animation-delay: 0.38s; }
  .feedback-panel:nth-child(3) { animation-delay: 0.46s; }
  .feedback-panel:nth-child(4) { animation-delay: 0.54s; }

  .panel-title {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    margin-bottom: 14px;
    display: flex; align-items: center; gap: 8px;
  }
  .panel-icon { font-size: 16px; }

  .feedback-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .feedback-list li {
    font-size: 13px;
    line-height: 1.5;
    color: #94a3b8;
    padding: 8px 10px;
    background: var(--surface2);
    border-radius: 8px;
    display: flex; gap: 8px; align-items: flex-start;
  }
  .feedback-list li::before { content: attr(data-icon); flex-shrink: 0; font-size: 12px; }

  /* Summary */
  .summary-panel {
    background: linear-gradient(135deg, rgba(59,130,246,0.08), rgba(6,182,212,0.05));
    border: 1px solid rgba(59,130,246,0.2);
    border-radius: 16px;
    padding: 22px;
    animation: cardIn 0.5s ease 0.6s both;
  }
  .summary-panel p { font-size: 14px; line-height: 1.7; color: #94a3b8; }
  .summary-panel p strong { color: var(--text); }

  /* Error */
  .error-msg {
    display: none;
    background: rgba(239,68,68,0.1);
    border: 1px solid rgba(239,68,68,0.25);
    border-radius: 12px;
    padding: 14px 18px;
    color: #fca5a5;
    font-size: 13px;
    margin-top: 12px;
  }
  .error-msg.show { display: block; }
</style>
</head>
<body>
<div class="blob blob-1"></div>
<div class="blob blob-2"></div>

<div class="container">
  <header>
    <div class="header-inner">
      <div class="logo-icon">🎓</div>
      <div class="logo-text">Edu<span>AI</span></div>
      <div class="badge">Meta OpenEnv Hackathon</div>
    </div>
  </header>

  <div class="hero">
    <h1>AI <span class="gradient">Average Student</span><br/>Simulator</h1>
    <p>Paste your lecture transcript and let EduAI simulate how an average student understands your teaching — with actionable feedback.</p>
  </div>

  <!-- Upload / Input -->
  <div class="upload-card" id="inputSection">
    <label class="textarea-label">Lecture Transcript</label>
    <textarea id="transcriptInput" placeholder="Paste your lecture transcript here...

Example: 'Today we are going to learn about photosynthesis. Plants use sunlight to convert carbon dioxide and water into glucose...'"></textarea>
    <div class="error-msg" id="errorMsg"></div>
    <button class="analyze-btn" id="analyzeBtn" onclick="analyze()">
      <span>🔬</span> Analyze Lecture
    </button>
  </div>

  <!-- Loading -->
  <div class="loading" id="loadingSection">
    <div class="spinner"></div>
    <p>EduAI is simulating an average student...</p>
    <div class="loading-steps" id="loadingSteps">
      <div class="step active">📝 Reading transcript...</div>
      <div class="step" id="step2">🧠 Simulating student understanding...</div>
      <div class="step" id="step3">📊 Calculating scores...</div>
      <div class="step" id="step4">💡 Generating feedback...</div>
    </div>
  </div>

  <!-- Results -->
  <div class="results" id="resultsSection">
    <div class="results-header">
      <h2>📊 Analysis Results</h2>
      <button class="reset-btn" onclick="reset()">← New Analysis</button>
    </div>

    <div class="scores-grid" id="scoresGrid"></div>
    <div class="feedback-grid" id="feedbackGrid"></div>
    <div class="summary-panel" id="summaryPanel"></div>
  </div>
</div>

<script>
const API_KEY = ""; // Leave empty — handled by OpenEnv

async function analyze() {
  const transcript = document.getElementById("transcriptInput").value.trim();
  const errorMsg = document.getElementById("errorMsg");

  errorMsg.classList.remove("show");

  if (!transcript || transcript.length < 30) {
    errorMsg.textContent = "Please enter a longer lecture transcript (at least a few sentences).";
    errorMsg.classList.add("show");
    return;
  }

  // Show loading
  document.getElementById("inputSection").style.display = "none";
  document.getElementById("loadingSection").classList.add("show");
  document.getElementById("resultsSection").classList.remove("show");

  // Animate loading steps
  const steps = ["step2", "step3", "step4"];
  steps.forEach((id, i) => {
    setTimeout(() => {
      document.getElementById(id).classList.add("active");
    }, (i + 1) * 900);
  });

  try {
    const systemPrompt = `You are EduAI – an AI Average Student Simulator.
Analyze the lecture and return ONLY a JSON object (no markdown, no extra text):
{
  "understanding_score": <int 0-100>,
  "concept_clarity_score": <int 0-100>,
  "engagement_estimate": <int 0-100>,
  "difficulty_level": "Easy|Medium|Hard",
  "strengths": ["...", "..."],
  "weak_points": ["...", "..."],
  "improvement_suggestions": ["...", "..."],
  "teaching_tips": ["...", "..."],
  "summary": "..."
}`;

    const response = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-20250514",
        max_tokens: 1000,
        system: systemPrompt,
        messages: [{ role: "user", content: `Analyze this lecture transcript:\n\n${transcript}` }]
      })
    });

    const data = await response.json();
    const text = data.content?.map(c => c.text || "").join("") || "";
    const clean = text.replace(/```json|```/g, "").trim();
    const result = JSON.parse(clean);

    showResults(result);
  } catch (err) {
    document.getElementById("loadingSection").classList.remove("show");
    document.getElementById("inputSection").style.display = "block";
    errorMsg.textContent = "Something went wrong. Please try again.";
    errorMsg.classList.add("show");
  }
}

function scoreClass(score) {
  if (score >= 70) return "score-good";
  if (score >= 45) return "score-mid";
  return "score-low";
}

function showResults(r) {
  document.getElementById("loadingSection").classList.remove("show");
  document.getElementById("resultsSection").classList.add("show");

  // Scores
  const scores = [
    { label: "Understanding", value: r.understanding_score },
    { label: "Concept Clarity", value: r.concept_clarity_score },
    { label: "Engagement", value: r.engagement_estimate },
    { label: "Difficulty", value: null, difficulty: r.difficulty_level },
  ];

  document.getElementById("scoresGrid").innerHTML = scores.map(s => {
    if (s.difficulty) {
      return `<div class="score-card">
        <div class="score-label">${s.label}</div>
        <div class="score-value" style="font-size:28px;margin-top:8px;">
          <span class="difficulty-badge difficulty-${s.difficulty}">${s.difficulty}</span>
        </div>
      </div>`;
    }
    const cls = scoreClass(s.value);
    return `<div class="score-card ${cls}">
      <div class="score-label">${s.label}</div>
      <div class="score-value">${s.value}</div>
      <div class="score-bar"><div class="score-fill" data-pct="${s.value}"></div></div>
    </div>`;
  }).join("");

  // Animate bars
  setTimeout(() => {
    document.querySelectorAll(".score-fill").forEach(el => {
      el.style.width = el.dataset.pct + "%";
    });
  }, 100);

  // Feedback panels
  const panels = [
    { title: "Strengths", icon: "✅", items: r.strengths, itemIcon: "✓" },
    { title: "Weak Points", icon: "⚠️", items: r.weak_points, itemIcon: "!" },
    { title: "Improvement Suggestions", icon: "🔧", items: r.improvement_suggestions, itemIcon: "→" },
    { title: "Teaching Tips", icon: "💡", items: r.teaching_tips, itemIcon: "★" },
  ];

  document.getElementById("feedbackGrid").innerHTML = panels.map(p => `
    <div class="feedback-panel">
      <div class="panel-title"><span class="panel-icon">${p.icon}</span>${p.title}</div>
      <ul class="feedback-list">
        ${(p.items || []).map(item => `<li data-icon="${p.itemIcon}">${item}</li>`).join("")}
      </ul>
    </div>
  `).join("");

  // Summary
  document.getElementById("summaryPanel").innerHTML = `
    <div class="panel-title"><span class="panel-icon">📝</span>Overall Feedback</div>
    <p>${r.summary}</p>
  `;
}

function reset() {
  document.getElementById("resultsSection").classList.remove("show");
  document.getElementById("inputSection").style.display = "block";
  document.getElementById("transcriptInput").value = "";
  // Reset loading steps
  document.querySelectorAll(".step").forEach((el, i) => {
    if (i > 0) el.classList.remove("active");
  });
}
</script>
</body>
</html>
